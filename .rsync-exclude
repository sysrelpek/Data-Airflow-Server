# =============================================================================
# .rsync-exclude
# Only exclude what should NEVER go to the production server
# =============================================================================

# Python / Environment
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
htmlcov/
.coverage
airflow_home_test/

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temporary / Generated
temp_code/
*.log
*.tmp

# OS
.DS_Store
Thumbs.db

# ============================================
# Environment files - Only allow .env.prod
# ============================================
.env.dev
.env.test

# Explicitly allow .env.prod to be copied
!.env.prod

# Do not copy this file itself
.rsync-exclude