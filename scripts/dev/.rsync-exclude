# .rsync-exclude
# Files and directories to exclude when syncing to the production server

# Version control
.git/

# Local development
.venv/
venv/
*.egg-info/
dist/
build/

# Environment files (never sync real secrets!)
.env.dev
.env.test
.env.prod.example
.env.dev.example
.env.test.example

# Python cache & temporary files
__pycache__/
*.pyc
*.pyo
*.pyd

# Airflow runtime folders (created automatically on server)
airflow_home/
airflow_home_test/
.airflow/

# Logs and temporary data
logs/
*.log

# IDE / editor files
.idea/
.vscode/
*.swp
*.swo

# Tests & coverage
.coverage
htmlcov/
.pytest_cache/